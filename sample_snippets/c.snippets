# This is a comment.  It begins on the start of the line.
# Be sure to use TABS not spaces.
# To extend an existing snippet file, use:
# extends language
snippet guard
	#ifndef ${1:`toupper(expand("%:t:r"))`_DEFINED_H}
	#define $1

	$0

	#endif  // $1
snippet if
	if (${1:true}) {
		${0:${VISUAL}}
	}
snippet mal
	${1:type} *${2:var} = malloc(sizeof($1));
	$0
snippet cal
	${1:type} *${2:var} = calloc(${3:count}, sizeof($1));
	$0
